# ---- Supabase (frontend reads) ----
# Project Settings -> API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# Server-only. NEVER expose to the browser. Used by server components / route handlers.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ---- The following are set as SUPABASE EDGE FUNCTION secrets, not here ----
# (documented for reference — see README "Setup" section)
# GA4_PROPERTY_ID=123456789
# GSC_SITE_URL=https://www.yourdomain.com/     (or sc-domain:yourdomain.com)
# GOOGLE_SA_EMAIL=dashboard@your-project.iam.gserviceaccount.com
# GOOGLE_SA_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
